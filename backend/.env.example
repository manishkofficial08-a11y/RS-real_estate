# App
APP_NAME=AI SaaS Platform
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_saas_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Frontend

# Email / SMTP

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=mmeai.official@gmail.com
FRONTEND_URL=http://localhost:5173

# Social Publisher
# PUBLISHER_MODE options: mock, real, hybrid
# mock = never calls real APIs
# real = calls real APIs and fails if tokens/media are missing
# hybrid = tries real APIs, falls back to mock for demos
PUBLISHER_MODE=mock
PUBLIC_BACKEND_URL=http://localhost:8000

# Meta / Facebook / Instagram
META_GRAPH_VERSION=v20.0
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=

# YouTube Data API / OAuth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_PRIVACY_STATUS=private

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# Scheduled Publisher Worker
SCHEDULED_PUBLISHER_INTERVAL_SECONDS=60
SCHEDULED_PUBLISHER_BATCH_SIZE=25
DISABLE_SCHEDULED_PUBLISHER_WORKER=false

# Free Lead Generation Agent
# Use a unique User-Agent with a support email before production rollout.
LEAD_AGENT_USER_AGENT=MME-AI-Free-Lead-Agent/1.0
LEAD_AGENT_NOMINATIM_URL=https://nominatim.openstreetmap.org
LEAD_AGENT_OVERPASS_URLS=https://overpass.private.coffee/api/interpreter,https://overpass-api.de/api/interpreter,https://maps.mail.ru/osm/tools/overpass/api/interpreter

# Rekha — Founder Client Approach Agent
# Safe default: generates reviewable drafts but never sends automatically.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
REKHA_COMPANY_NAME=MMe-AI
REKHA_FOUNDER_NAME=Manish
REKHA_FOUNDER_PHONE=+91 8851144571
REKHA_FOUNDER_WHATSAPP_URL=https://wa.me/918851144571
REKHA_CONTACT_EMAIL=mmeai.official@gmail.com
REKHA_POSTAL_ADDRESS=
REKHA_BOOKING_URL=
REKHA_DEMO_HOURS=10:00 AM–5:00 PM IST
REKHA_AUTO_SEND_ENABLED=false
REKHA_DAILY_SEND_LIMIT=20
REKHA_WORKER_INTERVAL_SECONDS=60
REKHA_WORKER_BATCH_SIZE=25
DISABLE_REKHA_AUTOMATION_WORKER=false
REKHA_INBOUND_WEBHOOK_SECRET=
REKHA_IMAP_ENABLED=false
REKHA_IMAP_HOST=imap.gmail.com
REKHA_IMAP_PORT=993
REKHA_IMAP_USERNAME=
